# Copy this file to .env.local and fill in the values.

# URL of the RealAI backend (Render deployment).
# Either value works; REALAI_API_BASE is preferred for server-side use.
REALAI_API_BASE="https://your-service.onrender.com"
NEXT_PUBLIC_REALAI_API_BASE="https://your-service.onrender.com"

# Optional: server-side API key forwarded to the backend.
# If set here, the frontend never exposes it to the browser.
REALAI_API_KEY=""
