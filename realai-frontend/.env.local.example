# Copy this file to .env.local and fill in the values.

# ─── Option A: Full-stack on Vercel (no separate Python backend needed) ───────
# Point to any OpenAI-compatible provider and set your API key.
# OpenRouter lets you use GPT-4o, Claude, Gemini, Mistral and more with ONE key.
#   https://openrouter.ai/keys
#
# REALAI_API_BASE="https://openrouter.ai/api"
# REALAI_API_KEY="sk-or-v1-..."

# ─── Option B: OpenAI directly ────────────────────────────────────────────────
# REALAI_API_BASE="https://api.openai.com"
# REALAI_API_KEY="sk-..."

# ─── Option C: Self-hosted Python backend (Render / Railway / VPS) ────────────
# Run `python -m realai.api_server` and deploy it, then paste the URL below.
# REALAI_API_BASE="https://your-service.onrender.com"

# Set REALAI_API_BASE to whichever option you choose (no trailing slash, no /v1).
REALAI_API_BASE=""

# Server-side key forwarded to the backend.  Never exposed to the browser.
REALAI_API_KEY=""
