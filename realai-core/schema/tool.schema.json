{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentx.dev/schema/tool.schema.json",
  "title": "Tool Manifest",
  "type": "object",
  "required": [
    "name",
    "description",
    "input_schema",
    "output_schema",
    "safety"
  ],
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^[a-z0-9_\\-]+$"
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "input_schema": {
      "type": "object"
    },
    "output_schema": {
      "type": "object"
    },
    "safety": {
      "type": "string",
      "enum": ["safe", "guarded", "dangerous"]
    }
  },
  "additionalProperties": true
}
